def integer_nth_root(x, n):
    low, high = 0, x
    while low <= high:
        mid = (low + high) // 2
        power = mid ** n

        if power == x:
            return mid
        elif power < x:
            low = mid + 1
        else:
            high = mid - 1

    return high

